DATABASE_URL=postgresql+asyncpg://postgres:password@localhost/borne_db
SECRET_KEY=changeme-generate-a-strong-secret-in-production

# Fichiers uploadés (chemin relatif au répertoire d'exécution du backend)
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=20

# Sessions
SESSION_EXPIRY_MINUTES=10

# Worker d'impression
WORKER_POLL_INTERVAL_SECONDS=2

# Paiement mock (délai avant confirmation automatique)
PAYMENT_MOCK_DELAY_SECONDS=5

# Impression Windows
# Laisser vide pour utiliser l'imprimante par défaut du système
PRINTER_NAME=
# Chemin vers SumatraPDF.exe (portable recommandé, à placer dans backend/bin/)
SUMATRA_PATH=.\bin\SumatraPDF.exe

# Environnement : "development" (stub impression) ou "production" (impression réelle)
ENVIRONMENT=development

# Scanner WIA
# "mock" -> stub (images PNG de test)
# "real" -> scanner réel WIA (Canon G3030)
SCANNING_MODE=mock
SCANNER_WIA_DEVICE_INDEX=0
SCANNER_DEFAULT_RESOLUTION=200
SCANNER_TIMEOUT_SECONDS=60
