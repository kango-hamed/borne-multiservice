DATABASE_URL=postgresql+asyncpg://postgres:password@localhost/borne_db
SECRET_KEY=changeme-generate-a-strong-secret-in-production

# Fichiers uploadés (chemin relatif au répertoire d'exécution du backend)
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=20

# Sessions
SESSION_EXPIRY_MINUTES=10

# Worker d'impression
WORKER_POLL_INTERVAL_SECONDS=2

# Paiement mock (délai avant confirmation automatique)
PAYMENT_MOCK_DELAY_SECONDS=5

# Impression Windows
# Laisser vide pour utiliser l'imprimante par défaut du système
PRINTER_NAME=
# Chemin vers SumatraPDF.exe (portable recommandé, à placer dans backend/bin/)
SUMATRA_PATH=.\bin\SumatraPDF.exe

# Scan de document — scanner matériel de la borne
# Backend d'acquisition : "stub" (dev, sans matériel), "wia" (Windows),
#   "watched_folder" (scan-to-folder), "escl" (scanner réseau AirScan/Mopria)
SCANNER_BACKEND=stub
# Résolution de numérisation (dpi)
SCANNER_DPI=200
# Nombre maximal de pages numérisées par document
MAX_SCAN_PAGES=30
# Nom du périphérique WIA (vide = premier scanner détecté) — mode "wia"
SCANNER_NAME=
# Dossier surveillé pour le scan-to-folder — mode "watched_folder"
SCAN_WATCH_DIR=./scan_inbox
# Délai max d'attente d'une page (secondes) — modes "watched_folder"/"escl"
SCAN_WATCH_TIMEOUT_SECONDS=90
# URL de base du scanner eSCL (ex: http://192.168.1.50:80) — mode "escl"
SCANNER_ESCL_URL=

# Environnement : "development" (stub impression) ou "production" (impression réelle)
ENVIRONMENT=development
